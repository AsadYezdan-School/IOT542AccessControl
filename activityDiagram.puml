@startuml
start
!pragma useVerticalIf on
skinparam linetype ortho
skinparam shadowing false

title Access Control At The Door (Regular And Emergency Cases)

partition "Facility User" {
  :Present ID to door reader;
}

partition "Door Hardware" {
  :Log REQUEST (User ID, Timestamp, Door ID);
  if (Local cache contains decision for user?) then (Yes)
    :Use cached decision;
  else (No)
    :Send request to Policy Evaluation Engine;
  endif
  if (Access allowed?) then (Yes)
    :Log ALLOW ( Reason: standard);
    :Initiate defined access protocol;
    stop
  else (No)
    :Log DENY ( Reason: standard);
    :Access denied displayed;
  endif
}

partition "AMS Emergency Protocols" {
  if (Emergency declared?) then (Yes)
    :Capture Incident ID;

    if (Valid incident ID?) then (Yes)

      if (Access allowed under emergencyConditions?) then (No)
        if (Incident has breakGlass policy) then (Yes)
          :Log ALLOW (breakGlass);
          :Allow access;
          stop
        else (No)
        endif
        :Log DENY (hard constraint);
        stop
      else (Yes)
        :Log ALLOW (emergency);
        :Initiate emergency access protocol;
        stop
      endif

    else (No)
      :Log DENY (Reason: Invalid incident ID);
      :Entry denied;
      stop
    endif

  else (No)
    stop
  endif
}
@enduml